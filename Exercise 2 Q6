#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
#include <sys/types.h>
#include <sys/stat.h>

int main() {
    int fd;

    // Create and open the file
    fd = open("student.txt", O_CREAT | O_RDWR, 0644);

    if (fd < 0) {
        printf("File creation failed.\n");
    } else {
        printf("File 'student.txt' created successfully.\n");
        close(fd);
    }

    return 0;
}
