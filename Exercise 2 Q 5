#include <stdio.h>
#include <unistd.h>
#include <stdlib.h>
#include <sys/types.h>
#include <sys/wait.h>

int main() {
    int i;
    pid_t pid;

    // Create 3 child processes
    for (i = 1; i <= 3; i++) {
        pid = fork();

        if (pid < 0) {
            printf("Fork failed.\n");
            exit(1);
        }
        else if (pid == 0) {
            // Child process
            printf("Child %d --> PID = %d, PPID = %d\n",
                   i, getpid(), getppid());
            exit(0);
        }
    }

    // Parent waits for all child processes
    for (i = 1; i <= 3; i++) {
        wait(NULL);
    }

    printf("Parent --> PID = %d\n", getpid());

    return 0;
}
