#include <stdio.h>
#include <unistd.h>
#include <sys/types.h>
#include <sys/wait.h>

int main() {
    pid_t pid;

    // Create child process
    pid = fork();

    if (pid < 0) {
        printf("Fork failed.\n");
        return 1;
    }
    else if (pid == 0) {
        // Child process executes ls -l
        printf("Executing ls -l command...\n");
        execl("/bin/ls", "ls", "-l", NULL);

        // Executes only if execl() fails
        printf("Execution failed.\n");
    }
    else {
        // Parent process waits for child
        wait(NULL);
        printf("Parent process completed.\n");
    }

    return 0;
}
